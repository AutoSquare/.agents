{
  "name": "portable-agents",
  "description": "可迁移 Agent Skills + Rules + MCP 包（文献检索、Zotero、PPT、ppt-maker、campus-net、UI/UX 设计技能、Karpathy 编码准则等）；安装入口包含 Cursor 与 Codex 专用脚本。",
  "skillsRoot": "skills",
  "rulesRoot": "rules",
  "rulesCursor": "rules/cursor",
  "rulesUniversal": "rules/universal/AGENTS.md",
  "mcpServers": {
    "academic-research": {
      "source": "https://github.com/alisoroushmd/academic-research-mcp",
      "install": "git clone + python venv + pip install -r requirements.txt",
      "purpose": "multi-source academic search"
    },
    "zotero": {
      "source": "https://github.com/Xpropel/zotero-mcp",
      "install": "git clone + npm install + npm run build",
      "purpose": "local Zotero library access"
    },
    "deck-builder": {
      "source": "https://github.com/toontube/deck-builder",
      "install": "git clone + npm install + npm run build",
      "purpose": "structured editable PPTX generation"
    },
    "ppt-markdown": {
      "source": "https://www.npmjs.com/package/@botrun/mcp-ppt-generator",
      "install": "npx -y @botrun/mcp-ppt-generator",
      "purpose": "Markdown to PPTX"
    },
    "campus-net-mcp": {
      "source": "bundled: .agents/mcp-servers-src/campus-net-mcp",
      "install": ".agents/scripts/setup-cursor-agents.ps1 或 .agents/scripts/setup-codex-agents.ps1",
      "purpose": "通用学校 Profile：馆藏探测、会话与全文下载链路"
    }
  },
  "skillGroups": {
    "literatureAndPpt": [
      "literature-search",
      "campus-net-onboarding",
      "paper-screening",
      "paper-summary",
      "citation-export",
      "research-gap-analysis",
      "academic-ppt-builder",
      "ppt-maker"
    ],
    "mattpocockAdapted": [
